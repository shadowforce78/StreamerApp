<?xml version="1.0" encoding="utf-8"?>
<!-- ═══════════════════════════════════════════════════════════════════
     activity_main.xml — Écran de découverte du serveur
     ═══════════════════════════════════════════════════════════════════
     Layout principal avec :
     - Un indicateur de recherche (ProgressBar + texte)
     - Une carte serveur qui apparaît quand un serveur est détecté
     - Un bouton de connexion
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:padding="32dp">

    <!-- ── Icône / Logo ── -->
    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📺 Screen Share"
        android:textColor="#E0E0E0"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- ── Texte de statut ── -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recherche d'un serveur sur le réseau..."
        android:textColor="#B0B0C0"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/appTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <!-- ── Indicateur de recherche ── -->
    <ProgressBar
        android:id="@+id/searchingProgress"
        style="?android:attr/progressBarStyle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="visible"
        android:indeterminateTint="#6C63FF"
        app:layout_constraintTop_toBottomOf="@id/statusText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <!-- ═══════════════════════════════════════════════════════════
         Carte Serveur — Visible uniquement quand un serveur est détecté
         ═══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/serverCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/searchingProgress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="500dp"
        android:layout_marginTop="24dp">

        <!-- Nom du serveur -->
        <TextView
            android:id="@+id/serverNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Serveur"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:drawablePadding="8dp"
            android:layout_gravity="center" />

        <!-- IP et ports -->
        <TextView
            android:id="@+id/serverIpText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="192.168.1.x"
            android:textColor="#9090A0"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp" />

        <!-- Bouton de connexion -->
        <Button
            android:id="@+id/connectButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Se connecter"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:background="@drawable/button_connect"
            android:layout_marginTop="20dp"
            android:enabled="true" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
